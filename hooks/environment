#!/usr/bin/env bash
#
# Buildkite environment hook. Runs BEFORE Buildkite's default checkout
# so that:
#   1. ENTIRE_TOKEN is available to git-remote-entire when the native
#      `git clone entire://<repo>` resolves the entire:// helper, and
#   2. git-remote-entire itself is on $PATH (downloaded fresh each job
#      because Buildkite Cloud hosted agents are stateless containers).
#
# Was hooks/pre-command in earlier versions of this plugin. pre-command
# fires AFTER checkout, which doesn't work for pipelines whose source is
# an entire:// URL.
set -euo pipefail

URL="${BUILDKITE_PLUGIN_ENTIRE_CORE_AUTH_URL:?entire-core-auth: url is required}"
ACCOUNT="${BUILDKITE_PLUGIN_ENTIRE_CORE_AUTH_ACCOUNT:?entire-core-auth: account is required}"
AUDIENCE="${BUILDKITE_PLUGIN_ENTIRE_CORE_AUTH_AUDIENCE:-${URL%/}/api/authz/sts}"

# Pinned per-plugin-tag. To upgrade the git-remote-entire being installed
# on the agent, bump this constant to a sha from entireio/cli main and
# cut a new plugin tag. The artifact is published per-commit by
# entireio/cli's publish-git-remote-entire workflow (goreleaser) to a
# dedicated public S3 bucket in us-east-2 (linux amd64 + arm64 only —
# hosted Buildkite agents are always linux). Note: shas older than the
# workflow's introduction aren't in the bucket; entiredb shas from
# before the command moved (like this one) predate it.
GIT_REMOTE_ENTIRE_SHA="536f074ed85b1728b54a3c777b73bc39ea4cba7b"
GIT_REMOTE_ENTIRE_BASE="https://entire-public-release-bucket-7f3e2a01c9b48d56.s3.us-east-2.amazonaws.com/commit/${GIT_REMOTE_ENTIRE_SHA}"

echo "~~~ :key: Requesting Buildkite OIDC token"
echo "audience=${AUDIENCE}"

# Buildkite stamps --audience onto the issued token's aud claim, which
# entire-core's STS verifies against the provider row's audience to
# foreclose cross-deployment replay. The agent CLI handles auth to
# agent.buildkite.com itself; no permission flag analogous to GitHub's
# id-token: write is required.
if ! OIDC_TOKEN="$(buildkite-agent oidc request-token --audience "${AUDIENCE}" 2>&1)"; then
  echo "^^^ +++"
  echo "Failed to fetch OIDC token from Buildkite:" >&2
  echo "${OIDC_TOKEN}" >&2
  exit 1
fi
if [[ -z "$OIDC_TOKEN" ]]; then
  echo "buildkite-agent oidc request-token returned empty token" >&2
  exit 1
fi

echo "~~~ :lock: Exchanging for entire-core session token"

# Buildkite doesn't have a per-value ::add-mask:: equivalent, so we rely
# on the agent's default redacted-vars patterns (*_TOKEN, *_SECRET, ...)
# masking ENTIRE_TOKEN from later log output, plus not echoing OIDC_TOKEN
# from this hook. Don't `set -x` here.

RESP="$(mktemp)"
trap 'rm -f "$RESP"' EXIT

# RFC 8693 token exchange. audience = the relying party for the issued
# token (the entire-core deployment base URL); resource = the SA to
# assume. pkg/op dispatches federated vs operator on subject_token's iss.
HTTP_CODE="$(curl -sLS -o "$RESP" -w '%{http_code}' \
  -X POST "${URL%/}/oauth/token" \
  -u "entire-cli:" \
  -H 'Content-Type: application/x-www-form-urlencoded' \
  --data-urlencode 'grant_type=urn:ietf:params:oauth:grant-type:token-exchange' \
  --data-urlencode 'subject_token_type=urn:ietf:params:oauth:token-type:jwt' \
  --data-urlencode "subject_token=${OIDC_TOKEN}" \
  --data-urlencode "audience=${URL%/}" \
  --data-urlencode "resource=${ACCOUNT}")"

if [[ "$HTTP_CODE" != "200" ]]; then
  echo "^^^ +++"
  echo "Token exchange failed (HTTP ${HTTP_CODE}). Common causes:" >&2
  echo "  - no binding for this (provider, account)" >&2
  echo "  - attribute_filter mismatch (e.g. binding only allows pushes to main but pipeline ran on a PR)" >&2
  echo "  - Buildkite OIDC audience mismatch with the provider row's accepted aud" >&2
  cat "$RESP" >&2 || true
  echo >&2
  reason="$(jq -r '.error_description // .error // "unknown error"' < "$RESP" 2>/dev/null || echo "unknown error")"
  buildkite-agent annotate --style error --context entire-core-auth \
    "entire-core auth failed: ${reason}" || true
  exit 1
fi

ACCESS_TOKEN="$(jq -r '.access_token' < "$RESP")"
EXPIRES_IN="$(jq -r '.expires_in' < "$RESP")"

if [[ -z "$ACCESS_TOKEN" || "$ACCESS_TOKEN" == "null" ]]; then
  echo "STS response missing access_token" >&2
  cat "$RESP" >&2 || true
  exit 1
fi

echo "Got entire-core session token (expires in ${EXPIRES_IN}s)"

# Export ENTIRE_TOKEN and ENTIRE_CORE_AUTH_BASE_URL so subsequent
# `entire-core` invocations pick the token up and target the right
# deployment without per-step plumbing. Mirrors the GitHub Actions wrapper.
export ENTIRE_TOKEN="$ACCESS_TOKEN"
export ENTIRE_CORE_AUTH_BASE_URL="${URL%/}"

echo "~~~ :package: Installing git-remote-entire"

# Hosted Buildkite agents are linux containers. The goreleaser config in
# entiredb only publishes linux artifacts for git-remote-entire; this hook
# is the wrong place to run on darwin self-hosted agents (those should
# install git-remote-entire via their own provisioning instead).
os="$(uname -s | tr '[:upper:]' '[:lower:]')"
if [[ "$os" != "linux" ]]; then
  echo "git-remote-entire is only published for linux (detected: $os)" >&2
  buildkite-agent annotate --style error --context entire-core-auth \
    "entire-core-auth plugin: git-remote-entire is linux-only; this agent reports os=${os}" || true
  exit 1
fi

case "$(uname -m)" in
  x86_64|amd64) arch=amd64 ;;
  aarch64|arm64) arch=arm64 ;;
  *) echo "Unsupported architecture: $(uname -m)" >&2; exit 1 ;;
esac

BIN_DIR="$(mktemp -d -t entire-bin-XXXXXXXX)"
TARBALL="${BIN_DIR}/git-remote-entire.tar.gz"
BIN_URL="${GIT_REMOTE_ENTIRE_BASE}/git-remote-entire_linux_${arch}.tar.gz"

if ! curl -fsSL -o "$TARBALL" "$BIN_URL"; then
  echo "Failed to download git-remote-entire from $BIN_URL" >&2
  buildkite-agent annotate --style error --context entire-core-auth \
    "entire-core-auth plugin: failed to fetch git-remote-entire from ${BIN_URL}" || true
  exit 1
fi

tar -xzf "$TARBALL" -C "$BIN_DIR"
rm -f "$TARBALL"
chmod +x "${BIN_DIR}/git-remote-entire"
mv -v "${BIN_DIR}/git-remote-entire" /usr/local/bin

echo "Installed git-remote-entire (${GIT_REMOTE_ENTIRE_SHA:0:12}, linux/${arch}) to /usr/local/bin"
